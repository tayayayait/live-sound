# Local Supabase Edge Function secrets.
# Copy this file to supabase/functions/.env for local serving only.
# Do not commit real values.

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

GOOGLE_CLOUD_PROJECT=<google-cloud-project-id>
GEMINI_API_KEY=<gemini-api-key>

# Fill this last after Cloud Run bridge is deployed.
# Local bridge default can be used during development.
STT_BRIDGE_WS_URL=ws://localhost:8787
