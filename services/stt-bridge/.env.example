# Local Cloud Run bridge development values.
# Copy this file to services/stt-bridge/.env for local development only.
# Do not commit real values.

PORT=8787

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

GOOGLE_CLOUD_PROJECT=<google-cloud-project-id>
GOOGLE_CLOUD_LOCATION=global
GOOGLE_SPEECH_RECOGNIZER=projects/<google-cloud-project-id>/locations/global/recognizers/_

GEMINI_API_KEY=<gemini-api-key>

# true = local test mode without real Google STT.
# false = use Google Speech-to-Text credentials/service account.
USE_MOCK_STT=true
