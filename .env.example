# Browser-safe frontend values only.
# Copy this file to .env.local and fill the values.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-or-anon-key>

# Optional. If blank, the frontend uses:
# ${VITE_SUPABASE_URL}/functions/v1/meeting-api
VITE_MEETING_API_BASE_URL=
